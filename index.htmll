            screenshotSyllabusData = JSON.parse(JSON.stringify(BASE_SCREENSHOT_SYLLABUS));

            // Load custom MERN lectures
            const customMern = JSON.parse(localStorage.getItem('custom-mern-lectures')) || [];
            customMern.forEach(lec => {
                if(mernSyllabusData[lec.phaseIdx]) {
                    mernSyllabusData[lec.phaseIdx].lectures.push(lec);
                }
            });

            // Load custom Screenshot Topics
            const customScreenshot = JSON.parse(localStorage.getItem('custom-screenshot-topics')) || [];
            customScreenshot.forEach(topic => {
                const zone = screenshotSyllabusData.find(z => z.id === topic.zoneId);
                if(zone) {
                    zone.topics.push(topic);
                }
            });
        }

        // Render target options inside selector dropdown dynamically
        function updateTargetModuleDropdown() {
            const dropdown = document.getElementById('topic-target-module');
            const targetLabel = document.getElementById('target-phase-label');
            const durationContainer = document.getElementById('duration-input-container');
            dropdown.innerHTML = '';

            if (activeMode === 'mern') {
                targetLabel.textContent = "Select Target Phase Location";
                durationContainer.style.display = 'block';
                mernSyllabusData.forEach((phase, idx) => {
                    const opt = document.createElement('option');
                    opt.value = idx;
                    opt.textContent = `Phase ${idx + 1}: ${phase.phaseTitle.split(':')[0]}`;
                    dropdown.appendChild(opt);
                });
            } else {
                targetLabel.textContent = "Current Active Zone";
                durationContainer.style.display = 'none';
                const currentZone = screenshotSyllabusData.find(z => z.id === screenshotZoneFilter);
                if (currentZone) {
                    const opt = document.createElement('option');
                    opt.value = currentZone.id;
                    opt.textContent = currentZone.name;
                    dropdown.appendChild(opt);
                }
            }
        }

        // Process adding custom topics dynamically
        function handleFormSubmit(e) {
            e.preventDefault();
            const topicName = document.getElementById('topic-name-input').value.trim();
            const isImportant = document.getElementById('topic-important-input').checked;
            const targetValue = document.getElementById('topic-target-module').value;
            const priority = isImportant ? 5 : 3;

            if (activeMode === 'mern') {
                const duration = document.getElementById('topic-duration-input').value.trim() || "30m 00s";
                const phaseIdx = parseInt(targetValue, 10);
                
                // Get maximum current lecture ID to assign next unique sequence id
                let maxId = 100;
                mernSyllabusData.forEach(p => {
                    p.lectures.forEach(l => { if (l.id > maxId) maxId = l.id; });
                });
                const nextId = maxId + 1;

                const newLec = {
                    id: nextId,
                    name: topicName + " (Custom)",
                    duration: duration,
                    priority: priority,
                    seconds: 1800, // standard default
                    isCustom: true // marker to allow deletion
                };

                const customMern = JSON.parse(localStorage.getItem('custom-mern-lectures')) || [];
                newLec.phaseIdx = phaseIdx;
                customMern.push(newLec);
                localStorage.setItem('custom-mern-lectures', JSON.stringify(customMern));
                showToast("Custom lecture added successfully!", "success");

            } else {
                const zoneId = targetValue;
                const zone = screenshotSyllabusData.find(z => z.id === zoneId);
                const nextId = `S-CUSTOM-${Date.now()}`;

                const newTopic = {
                    id: nextId,
                    name: topicName + " (Custom)",
                    priority: priority,
                    zoneId: zoneId,
                    isCustom: true // marker to allow deletion
                };

                const customScreenshot = JSON.parse(localStorage.getItem('custom-screenshot-topics')) || [];
                customScreenshot.push(newTopic);
                localStorage.setItem('custom-screenshot-topics', JSON.stringify(customScreenshot));
                showToast("Custom topic added successfully to Zone!", "success");
            }

            // Reset Form Fields
            document.getElementById('topic-name-input').value = '';
            document.getElementById('topic-duration-input').value = '';
            document.getElementById('topic-important-input').checked = false;

            // Re-render
            initSyllabusDatasets();
            renderWorkspace();
        }

        // Delete Custom items
        function deleteCustomMernLecture(id) {
            let customMern = JSON.parse(localStorage.getItem('custom-mern-lectures')) || [];
            customMern = customMern.filter(l => l.id !== id);
            localStorage.setItem('custom-mern-lectures', JSON.stringify(customMern));
            
            // Clean checked state if it was checked
            if (mernChecked[id]) {
                delete mernChecked[id];
                localStorage.setItem('mern-checked-videos', JSON.stringify(mernChecked));
            }

            showToast("Custom topic removed.", "info");
            initSyllabusDatasets();
            renderWorkspace();
        }

        function deleteCustomScreenshotTopic(id) {
            let customScreenshot = JSON.parse(localStorage.getItem('custom-screenshot-topics')) || [];
            customScreenshot = customScreenshot.filter(t => t.id !== id);
            localStorage.setItem('custom-screenshot-topics', JSON.stringify(customScreenshot));

            // Clean checked state if it was checked
            if (screenshotChecked[id]) {
                delete screenshotChecked[id];
                localStorage.setItem('screenshot-zones-checked-videos', JSON.stringify(screenshotChecked));
            }

            showToast("Custom topic removed.", "info");
            initSyllabusDatasets();
            renderWorkspace();
        }

        // Render Workspace Content Based on mode
        function renderWorkspace() {
            const container = document.getElementById('workspace-container');
            container.innerHTML = '';

            if (activeMode === 'mern') {
                renderMernSyllabus(container);
            } else {
                renderScreenshotSyllabus(container);
            }

            calculateStatistics();
            renderFilters();
            updateTargetModuleDropdown();
            updateTabButtonHighlightStates();
        }

        // Render pristine MERN stack
        function renderMernSyllabus(container) {
            mernSyllabusData.forEach((phase, phaseIdx) => {
                // Apply search and filter criteria
                const filteredLectures = phase.lectures.filter(lec => {
                    const matchesSearch = lec.name.toLowerCase().includes(searchQuery.toLowerCase());
                    if (!matchesSearch) return false;

                    if (mernFilter === 'stars') {
                        return lec.priority === 5;
                    } else if (mernFilter === 'optional') {
                        return phase.phaseTitle.includes("Phase 6B");
                    }
                    return true;
                });

                if (filteredLectures.length === 0) return;

                const card = document.createElement('div');
                card.className = "bg-white dark:bg-slate-950 rounded-2xl shadow-md border border-slate-200 dark:border-slate-800 overflow-hidden phase-card transition duration-200 hover:shadow-lg";
                
                const starsHTML = (priority) => {
                    if (priority === 0) return `<span class="text-slate-400 dark:text-slate-500 text-xs italic">Optional Relational</span>`;
                    return `<span class="text-goldstar text-base">` + '★'.repeat(priority) + `</span>`;
                };

                let tableRows = filteredLectures.map(lec => {
                    const isChecked = mernChecked[lec.id] ? 'checked' : '';
                    const isImportant = lec.priority === 5;
                    
                    // Extra Bold classing and visual callout for Must-Need items
                    const nameClass = isImportant 
                        ? 'font-black text-slate-900 dark:text-white tracking-wide border-l-4 border-amber-500 pl-2' 
                        : 'font-semibold text-slate-800 dark:text-slate-200';

                    const rowHighlightClass = isImportant
                        ? 'bg-amber-50/25 dark:bg-amber-950/5 border-b border-slate-100 dark:border-slate-900 hover:bg-amber-50/40 dark:hover:bg-amber-950/10'
                        : 'border-b border-slate-100 dark:border-slate-900 hover:bg-slate-50/50 dark:hover:bg-slate-900/40';

                    const priorityBadge = isImportant
                        ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-extrabold uppercase tracking-wide bg-amber-100 text-amber-800 dark:bg-amber-950/50 dark:text-amber-400 border border-amber-200 dark:border-amber-900/40 mr-1.5 select-none">🔥 Must Need</span>`
                        : '';

                    const deleteButton = lec.isCustom
                        ? `<button onclick="deleteCustomMernLecture(${lec.id})" class="ml-2 text-red-500 hover:text-red-700 text-sm no-print" title="Delete Topic">❌</button>`
                        : '';

                    return `
                        <tr class="${rowHighlightClass} transition">
                            <td class="px-4 py-3.5 text-center font-bold text-slate-400 dark:text-slate-600 text-xs">${lec.id}</td>
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <input type="checkbox" ${isChecked} onchange="toggleMernLecture(${lec.id}, ${lec.seconds})" class="interactive-checkbox w-4.5 h-4.5 rounded text-brandteal focus:ring-brandteal border-slate-350 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 cursor-pointer transition">
                                        <span class="print-checkbox-indicator hidden"></span>
                                        <div class="flex flex-wrap items-center gap-1">
                                            ${priorityBadge}
                                            <span class="${nameClass} text-sm leading-snug">${lec.name}</span>
                                        </div>
                                    </div>
                                    ${deleteButton}
                                </div>
                            </td>
                            <td class="px-4 py-3.5 text-slate-600 dark:text-slate-400 text-sm font-bold whitespace-nowrap">${lec.duration}</td>
                            <td class="px-4 py-3.5 text-right">${starsHTML(lec.priority)}</td>
                        </tr>
                    `;
                }).join('');

                card.innerHTML = `
                    <div class="bg-slate-50 dark:bg-slate-900/80 px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex flex-col md:flex-row md:items-center justify-between gap-2 phase-header">
                        <div>
                            <h2 class="text-lg font-bold text-slate-900 dark:text-white leading-tight">${phase.phaseTitle}</h2>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 italic">${phase.phaseObjective}</p>
                        </div>
                        <span class="text-xs font-bold text-brandteal bg-teal-50 dark:bg-teal-950/60 px-3 py-1 rounded-full shadow-sm whitespace-nowrap">${phase.phaseDuration}</span>
                    </div>
                    <div class="overflow-x-auto phase-content">
                        <table class="min-w-full divide-y divide-slate-100 dark:divide-slate-800">
                            <thead class="bg-slate-50/30 dark:bg-slate-950/30">
                                <tr>
                                    <th scope="col" class="px-4 py-3 text-center text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-16">No.</th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Video Lecture Topic</th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-32">Duration</th>
                                    <th scope="col" class="px-4 py-3 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-36">Job Priority</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-900 bg-white dark:bg-slate-950">
                                ${tableRows}
                            </tbody>
                        </table>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Render Screenshot-aligned tracks as 99-video format tables
        function renderScreenshotSyllabus(container) {
            screenshotSyllabusData.forEach((zone) => {
                if (screenshotZoneFilter !== 'all' && zone.id !== screenshotZoneFilter) return;

                const filteredTopics = zone.topics.filter(top => {
                    return top.name.toLowerCase().includes(searchQuery.toLowerCase());
                });

                if (filteredTopics.length === 0 && searchQuery !== '') return;

                const card = document.createElement('div');
                card.className = "bg-white dark:bg-slate-950 rounded-2xl shadow-md border border-slate-200 dark:border-slate-800 overflow-hidden phase-card transition duration-200 hover:shadow-lg";

                // Build project checklists that auto-save state
                const projectsDescription = zone.projects ? `
                    <div class="p-3 bg-slate-100 dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800">
                        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">💡 Target Projects Matrix</span>
                        <div class="flex flex-wrap gap-2">
                            ${zone.projects.map((proj, idx) => {
                                const storageKey = `screenshot-checked-${zone.id}-proj-${idx}`;
                                const isChecked = localStorage.getItem(storageKey) === 'true' ? 'checked' : '';
                                return `
                                    <label class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-md text-xs font-semibold cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-900 select-none">
                                        <input type="checkbox" ${isChecked} onchange="toggleProjectKey('${storageKey}')" class="w-4 h-4 rounded text-brandteal focus:ring-brandteal bg-slate-50 cursor-pointer">
                                        <span class="text-slate-700 dark:text-slate-300">${proj}</span>
                                    </label>
                                `;
                            }).join('')}
                        </div>
                    </div>
                ` : '';

                const resourcesDescription = zone.resources ? `
                    <div class="p-3 bg-slate-100 dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-800">
                        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">📚 Recommended Learning Resources</span>
                        <ul class="list-disc list-inside space-y-0.5">
                            ${zone.resources.map(res => `<li class="text-xs text-slate-600 dark:text-slate-300">${res}</li>`).join('')}
                        </ul>
                    </div>
                ` : '';

                const headerMetadataBlock = `
                    <div class="px-6 py-4 bg-slate-50 dark:bg-slate-900/40 border-b border-slate-200 dark:border-slate-800 space-y-3">
                        <div class="flex items-center gap-2">
                            <span class="text-2xl">${zone.emoji}</span>
                            <h2 class="text-lg font-bold text-slate-900 dark:text-white leading-tight">${zone.name}</h2>
                        </div>
                        <p class="text-xs text-slate-500 dark:text-slate-400 italic">${zone.description}</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 pt-1">
                            ${projectsDescription}
                            ${resourcesDescription}
                        </div>
                    </div>
                `;

                const starsHTML = (priority) => {
                    return `<span class="text-goldstar text-base">` + '★'.repeat(priority) + `</span>`;
                };

                let tableRows = filteredTopics.map(top => {
                    const isChecked = screenshotChecked[top.id] ? 'checked' : '';
                    const isImportant = top.priority === 5;

                    // Extra Bold styling & borders on critical items
                    const nameClass = isImportant 
                        ? 'font-black text-slate-900 dark:text-white tracking-wide border-l-4 border-amber-500 pl-2' 
                        : 'font-semibold text-slate-800 dark:text-slate-200';

                    const rowHighlightClass = isImportant
                        ? 'bg-amber-50/25 dark:bg-amber-950/5 border-b border-slate-100 dark:border-slate-900 hover:bg-amber-50/40 dark:hover:bg-amber-950/10'
                        : 'border-b border-slate-100 dark:border-slate-900 hover:bg-slate-50/50 dark:hover:bg-slate-900/40';

                    const priorityBadge = isImportant
                        ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-extrabold uppercase tracking-wide bg-amber-100 text-amber-800 dark:bg-amber-950/50 dark:text-amber-400 border border-amber-200 dark:border-amber-900/40 mr-1.5 select-none">🔥 Must Need</span>`
                        : '';

                    const deleteButton = top.isCustom
                        ? `<button onclick="deleteCustomScreenshotTopic('${top.id}')" class="ml-2 text-red-500 hover:text-red-700 text-sm no-print" title="Delete Topic">❌</button>`
                        : '';

                    return `
                        <tr class="${rowHighlightClass} transition">
                            <td class="px-4 py-3.5 text-center font-bold text-slate-400 dark:text-slate-600 text-xs">${top.id}</td>
                            <td class="px-4 py-3.5">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <input type="checkbox" ${isChecked} onchange="toggleScreenshotTopic('${top.id}')" class="interactive-checkbox w-4.5 h-4.5 rounded text-brandteal focus:ring-brandteal border-slate-350 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 cursor-pointer transition">
                                        <span class="print-checkbox-indicator hidden"></span>
                                        <div class="flex flex-wrap items-center gap-1">
                                            ${priorityBadge}
                                            <span class="${nameClass} text-sm leading-snug">${top.name}</span>
                                        </div>
                                    </div>
                                    ${deleteButton}
                                </div>
                            </td>
                            <td class="px-4 py-3.5 text-right">${starsHTML(top.priority)}</td>
                        </tr>
                    `;
                }).join('');

                card.innerHTML = `
                    ${headerMetadataBlock}
                    <div class="overflow-x-auto phase-content">
                        <table class="min-w-full divide-y divide-slate-100 dark:divide-slate-800">
                            <thead class="bg-slate-50/30 dark:bg-slate-950/30">
                                <tr>
                                    <th scope="col" class="px-4 py-3 text-center text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-24">Code</th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Whiteboard Topic Checklist Item</th>
                                    <th scope="col" class="px-4 py-3 text-right text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider w-36">Priority Rating</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-900 bg-white dark:bg-slate-950">
                                ${tableRows || `<tr><td colspan="3" class="text-center py-6 text-xs text-slate-400">No matching topics found.</td></tr>`}
                            </tbody>
                        </table>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Navigation button highlights based on active track selection
        function updateTabButtonHighlightStates() {
            const buttonIds = ['mern', 'web', 'devops', 'dsa', 'ml', 'system_design', 'web3'];
            buttonIds.forEach(id => {
                const btn = document.getElementById(`nav-btn-${id}`);
                if (btn) {
                    btn.className = "px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800";
                }
            });

            // Highlight the active button
            let activeTargetId = activeMode === 'mern' ? 'mern' : screenshotZoneFilter;
            const activeBtn = document.getElementById(`nav-btn-${activeTargetId}`);
            if (activeBtn) {
                activeBtn.className = "px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-md flex items-center gap-1.5 border bg-brandteal text-white border-brandteal hover:brightness-110";
            }
        }

        // Checklist State Mutators
        function toggleMernLecture(id, seconds) {
            if (mernChecked[id]) {
                delete mernChecked[id];
                showToast("MERN Video marked as pending 📝", "info");
            } else {
                mernChecked[id] = seconds;
                showToast("MERN Video marked as completed! 🎉", "success");
            }
            localStorage.setItem('mern-checked-videos', JSON.stringify(mernChecked));
            calculateStatistics();
        }

        // Project Key Persistency
        function toggleProjectKey(key) {
            const current = localStorage.getItem(key) === 'true';
            localStorage.setItem(key, !current);
            showToast("Project matrix item updated.", "success");
        }

        function toggleScreenshotTopic(id) {
            if (screenshotChecked[id]) {
                delete screenshotChecked[id];
                showToast("Whiteboard topic set to pending.", "info");
            } else {
                screenshotChecked[id] = true;
                showToast("Whiteboard topic completed! 🌟", "success");
            }
            localStorage.setItem('screenshot-zones-checked-videos', JSON.stringify(screenshotChecked));
            calculateStatistics();
        }

        // Dynamic statistics computation
        function calculateStatistics() {
            if (activeMode === 'mern') {
                document.getElementById('metrics-syllabus-title').textContent = "MERN Course Blueprint";
                
                // Dynamic counts that respect custom topics added
                let totalLectures = 0;
                mernSyllabusData.forEach(p => {
                    totalLectures += p.lectures.length;
                });

                document.getElementById('metrics-count-total').textContent = `${totalLectures} Lectures`;
                document.getElementById('metrics-description-sub').textContent = "Uncompromised sequence tracking structured across 12 targeted placement phases.";
                document.getElementById('metrics-duration').textContent = "114h 51m";

                let completedCount = 0;
                let completedSeconds = 0;
                for (const key in mernChecked) {
                    completedCount++;
                    completedSeconds += mernChecked[key];
                }

                document.getElementById('completed-fraction').textContent = `${completedCount} / ${totalLectures}`;
                
                const percentage = totalLectures > 0 ? Math.round((completedCount / totalLectures) * 100) : 0;
                document.getElementById('overall-percentage').textContent = `${percentage}%`;
                document.getElementById('overall-progress-bar').style.width = `${percentage}%`;
            } else {
                const currentZone = screenshotSyllabusData.find(z => z.id === screenshotZoneFilter);
                const zoneTitle = currentZone ? currentZone.name : "Screenshot Track";
                const totalTopics = currentZone ? currentZone.topics.length : 0;

                document.getElementById('metrics-syllabus-title').textContent = zoneTitle;
                document.getElementById('metrics-description-sub').textContent = currentZone ? currentZone.description : "Specialized structural sequence roadmap.";

                document.getElementById('metrics-count-total').textContent = `${totalTopics} Topics`;
                document.getElementById('metrics-duration').textContent = "Sunday Track Focus";

                let completedCount = 0;
                if (currentZone) {
                    currentZone.topics.forEach(topic => {
                        if (screenshotChecked[topic.id]) {
                            completedCount++;
                        }
                    });
                }

                document.getElementById('completed-fraction').textContent = `${completedCount} / ${totalTopics}`;
                const percentage = totalTopics > 0 ? Math.round((completedCount / totalTopics) * 100) : 0;
                document.getElementById('overall-percentage').textContent = `${percentage}%`;
                document.getElementById('overall-progress-bar').style.width = `${percentage}%`;
            }
        }

        // Set specific View Track from navigation panel
        function setTrackView(mode, zoneFilter) {
            activeMode = mode;
            screenshotZoneFilter = zoneFilter;
            
            localStorage.setItem('curriculum-active-mode', mode);
            if (mode === 'screenshot') {
                localStorage.setItem('screenshot-active-zone', zoneFilter);
            }

            searchQuery = '';
            document.getElementById('search-bar').value = '';
            renderWorkspace();
        }

        // Render dynamic filtering buttons
        function renderFilters() {
            const filterWrapper = document.getElementById('filters-wrapper');
            filterWrapper.innerHTML = '';

            if (activeMode === 'mern') {
                filterWrapper.innerHTML = `
                    <span class="text-xs font-bold text-slate-400 mr-1">Blueprint Filters:</span>
                    <button onclick="setMernFilter('all')" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${mernFilter === 'all' ? 'bg-brandteal text-white' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' }">All Lectures</button>
                    <button onclick="setMernFilter('stars')" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${mernFilter === 'stars' ? 'bg-brandteal text-white' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' }">⭐⭐⭐⭐⭐ Job Priority</button>
                    <button onclick="setMernFilter('optional')" class="px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${mernFilter === 'optional' ? 'bg-brandteal text-white' : 'text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800' }">Phase 6B (Optional SQL)</button>
                `;
            } else {
                filterWrapper.innerHTML = `
                    <span class="text-xs font-bold text-slate-400 mr-1">Zone Status:</span>
                    <span class="text-xs font-extrabold text-brandteal bg-teal-50 dark:bg-teal-950/40 px-3 py-1.5 rounded-lg border border-teal-100 dark:border-teal-900/40">
                        Active Tracker Module
                    </span>
                `;
            }
        }

        function setMernFilter(f) {
            mernFilter = f;
            renderWorkspace();
        }

        function markCurrentSyllabusComplete() {
            if (activeMode === 'mern') {
                mernSyllabusData.forEach(p => {
                    p.lectures.forEach(l => {
                        mernChecked[l.id] = l.seconds;
                    });
                });
                localStorage.setItem('mern-checked-videos', JSON.stringify(mernChecked));
                showToast("All MERN Stack lectures completed! 🏆", "success");
            } else {
                const currentZone = screenshotSyllabusData.find(z => z.id === screenshotZoneFilter);
                if (currentZone) {
                    currentZone.topics.forEach(t => {
                        screenshotChecked[t.id] = true;
                    });
                    localStorage.setItem('screenshot-zones-checked-videos', JSON.stringify(screenshotChecked));
                    showToast(`All ${currentZone.name} targets completed! 🏆`, "success");
                }
            }
            renderWorkspace();
        }

        function resetCurrentSyllabusProgress() {
            if (activeMode === 'mern') {
                mernChecked = {};
                localStorage.setItem('mern-checked-videos', JSON.stringify(mernChecked));
                showToast("MERN Stack progress reset successfully. 💪", "info");
            } else {
                const currentZone = screenshotSyllabusData.find(z => z.id === screenshotZoneFilter);
                if (currentZone) {
                    currentZone.topics.forEach(t => {
                        delete screenshotChecked[t.id];
                    });
                    localStorage.setItem('screenshot-zones-checked-videos', JSON.stringify(screenshotChecked));
                    
                    currentZone.projects.forEach((_, idx) => {
                        localStorage.removeItem(`screenshot-checked-${currentZone.id}-proj-${idx}`);
                    });
                    showToast(`${currentZone.name} progress reset successfully. 💪`, "info");
                }
            }
            renderWorkspace();
        }

        // Toast Notification Pipeline
        function showToast(message, type = "success") {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `p-3.5 rounded-xl shadow-lg border text-xs font-bold flex items-center gap-2 transform translate-y-4 opacity-0 transition-all duration-300 pointer-events-auto bg-white dark:bg-slate-900 ${
                type === 'success' ? 'border-emerald-500/30 text-emerald-600 dark:text-emerald-400' : 'border-blue-500/30 text-blue-500 dark:text-blue-400'
            }`;
            
            toast.innerHTML = `
                <span>${type === 'success' ? '✅' : 'ℹ️'}</span>
                <span>${message}</span>
            `;
            container.appendChild(toast);

            setTimeout(() => {
                toast.classList.remove('translate-y-4', 'opacity-0');
            }, 10);

            setTimeout(() => {
                toast.classList.add('translate-y-4', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 2500);
        }

        // Theme Switcher Initializer
        const themeToggleBtn = document.getElementById('theme-toggle');
        const lightIcon = document.getElementById('light-icon');
        const darkIcon = document.getElementById('dark-icon');
        
        function initTheme() {
            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
                lightIcon.classList.remove('hidden');
                darkIcon.classList.add('hidden');
            } else {
                document.documentElement.classList.remove('dark');
                darkIcon.classList.remove('hidden');
                lightIcon.classList.add('hidden');
            }
        }
        
        themeToggleBtn.addEventListener('click', function() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('color-theme', 'light');
                darkIcon.classList.remove('hidden');
                lightIcon.classList.add('hidden');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('color-theme', 'dark');
                lightIcon.classList.remove('hidden');
                darkIcon.classList.add('hidden');
            }
        });

        // Search Action Listener
        document.getElementById('search-bar').addEventListener('input', (e) => {
            searchQuery = e.target.value;
            renderWorkspace();
        });

        // App startup
        window.onload = function() {
            initTheme();
            initSyllabusDatasets();
            renderWorkspace();
        }
    </script>
</body>
</html>
