<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>100xdevs Career Curriculum Syllabus Dashboard</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brandnavy: '#1A365D',
                        brandteal: '#0A5C6F',
                        goldstar: '#D69E2E',
                        slatecustom: '#0F172A'
                    },
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.05);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.2);
            border-radius: 4px;
        }
        .dark ::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2);
        }

        /* Print-specific layout parameters to generate standard PDF pages */
        @media print {
            @page {
                size: A4 portrait;
                margin: 12mm 15mm 12mm 15mm;
            }
            body {
                background: white !important;
                color: #1a1a1a !important;
                font-size: 10pt !important;
            }
            .no-print, .interactive-checkbox, #controls, #theme-toggle, .print-btn, .tab-navigation, .custom-topic-panel {
                display: none !important;
            }
            .phase-content, .zone-content {
                display: block !important;
                max-height: none !important;
                opacity: 1 !important;
            }
            .print-checkbox-indicator {
                display: inline-block !important;
                width: 12px;
                height: 12px;
                border: 1px solid #1a1a1a;
                border-radius: 2px;
                margin-right: 6px;
            }
            table {
                width: 100% !important;
                border-collapse: collapse !important;
            }
            tr {
                page-break-inside: avoid !important;
            }
            h1, h2, h3, .phase-header, .zone-header {
                page-break-after: avoid !important;
                page-break-inside: avoid !important;
            }
            .card, .phase-card {
                border: 1px solid #e2e8f0 !important;
                box-shadow: none !important;
                margin-bottom: 1rem !important;
                background: transparent !important;
                page-break-inside: avoid !important;
            }
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 transition-colors duration-300 min-h-screen flex flex-col">

    <!-- Sticky Floating Action bar for Web Interface -->
    <header class="sticky top-0 z-40 bg-white/90 dark:bg-slate-950/90 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-4 py-3 no-print">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <span class="text-2xl">🚀</span>
                <div>
                    <h1 class="font-bold text-lg text-slate-900 dark:text-white leading-tight">100xdevs Professional Hub</h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Pristine 99-Video Course, Cloud, System Design, Applied AI & Web3 Sunday Tracks</p>
                </div>
            </div>
            
            <div class="flex flex-wrap items-center gap-2 w-full sm:w-auto justify-end">
                <button onclick="markCurrentSyllabusComplete()" class="px-3 py-1.5 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-xs font-semibold transition">
                    Mark Selected Complete
                </button>
                <button onclick="resetCurrentSyllabusProgress()" class="px-3 py-1.5 bg-red-50 dark:bg-red-950/30 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-900/50 hover:bg-red-100 rounded-lg text-xs font-semibold transition">
                    Reset Selected Progress
                </button>

                <!-- Theme toggle button -->
                <button id="theme-toggle" class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:scale-105 transition-transform" title="Toggle Theme">
                    <svg id="light-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m2.122-10.607l-.707-.707m12.728 12.728l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path></svg>
                    <svg id="dark-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>

                <!-- Trigger Print To PDF -->
                <button onclick="window.print()" class="px-4 py-2.5 bg-brandteal hover:bg-teal-800 text-white rounded-xl font-semibold text-xs shadow-md flex items-center gap-1.5 hover:scale-105 transition duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    Save as Printable PDF
                </button>
            </div>
        </div>
    </header>

    <!-- Unified Navigation Buttons (MERN Stack list & dedicated Whiteboard channels) -->
    <nav class="bg-slate-100 dark:bg-slate-950 py-3 px-4 border-b border-slate-200 dark:border-slate-800 no-print tab-navigation">
        <div class="max-w-7xl mx-auto flex flex-col gap-3">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Select Learning Syllabus Track:</span>
            <div class="flex flex-wrap gap-2">
                <!-- 99 Videos Main Button -->
                <button id="nav-btn-mern" onclick="setTrackView('mern', 'all')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    🚀 MERN Course (99 Videos)
                </button>
                
                <!-- Web Dev Button -->
                <button id="nav-btn-web" onclick="setTrackView('screenshot', 'web')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    💻 Web Dev
                </button>
                
                <!-- DevOps and Cloud Button -->
                <button id="nav-btn-devops" onclick="setTrackView('screenshot', 'devops')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    ⚙️ DevOps & Cloud
                </button>
                
                <!-- DSA Button -->
                <button id="nav-btn-dsa" onclick="setTrackView('screenshot', 'dsa')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    🧠 DSA Track
                </button>
                
                <!-- AI Button -->
                <button id="nav-btn-ml" onclick="setTrackView('screenshot', 'ml')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    🤖 Applied AI
                </button>
                
                <!-- System Design Button -->
                <button id="nav-btn-system_design" onclick="setTrackView('screenshot', 'system_design')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    🏗️ System Design
                </button>

                <!-- Web3 Button -->
                <button id="nav-btn-web3" onclick="setTrackView('screenshot', 'web3')" class="px-4 py-2.5 rounded-xl text-xs font-extrabold transition-all duration-150 shadow-sm flex items-center gap-1.5 border border-slate-250 dark:border-slate-800">
                    🌐 Web3 (Sunday)
                </button>
            </div>
        </div>
    </nav>

    <!-- Main Workspace Container -->
    <main class="max-w-7xl mx-auto px-4 py-6 flex-1 w-full">
        
        <!-- Dashboard Executive Summary Cards -->
        <section id="executive-summary" class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-gradient-to-tr from-brandnavy to-slate-800 text-white p-5 rounded-2xl shadow-xl card flex flex-col justify-between">
                <div>
                    <span class="text-[10px] font-extrabold uppercase tracking-widest text-teal-400" id="metrics-syllabus-title">MERN Course Blueprint</span>
                    <h3 class="text-3xl font-black mt-1" id="metrics-count-total">99 Lectures</h3>
                    <p class="text-xs text-slate-300 mt-2" id="metrics-description-sub">Uncompromised sequence tracking structured across 12 targeted placement phases.</p>
                </div>
                <div class="mt-4 pt-3 border-t border-slate-700/30 flex justify-between items-center text-xs">
                    <span class="text-slate-400">Rating Tier:</span>
                    <span class="font-bold text-teal-400">System Architect Focus</span>
                </div>
            </div>
            
            <div class="bg-white dark:bg-slate-950 p-5 rounded-2xl shadow-md border border-slate-200 dark:border-slate-800 card flex flex-col justify-between">
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Completed Syllabus Work</span>
                    <h3 class="text-3xl font-extrabold mt-1 text-slate-900 dark:text-white" id="completed-fraction">0 / 99</h3>
                    <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-2 mt-3 overflow-hidden">
                        <div id="overall-progress-bar" class="bg-brandteal h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                </div>
                <div class="mt-4 text-[11px] text-slate-500 dark:text-slate-400 flex justify-between">
                    <span>Overall Checklist Completion:</span>
                    <span id="overall-percentage" class="font-bold text-brandteal">0%</span>
                </div>
            </div>

            <div class="bg-white dark:bg-slate-950 p-5 rounded-2xl shadow-md border border-slate-200 dark:border-slate-800 card flex flex-col justify-between">
                <div>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">Database & Scale Status</span>
                    <h3 class="text-3xl font-extrabold mt-1 text-emerald-600 dark:text-emerald-400" id="metrics-duration">114h 51m</h3>
                    <p class="text-xs text-slate-400 mt-2">Combined video runtime metrics with real-time checkbox status adjustment.</p>
                </div>
                <div class="mt-4 text-xs text-amber-500 font-semibold no-print flex items-center gap-1">
                    <span>⭐⭐⭐⭐⭐ Junior Job Ready rating system</span>
                </div>
            </div>
        </section>

        <!-- Add Custom Topic Panel (Dynamic & Persistent) -->
        <section class="mb-8 p-6 bg-white dark:bg-slate-950 rounded-2xl shadow border border-slate-200 dark:border-slate-800 no-print custom-topic-panel">
            <div class="flex items-center gap-2.5 mb-4">
                <span class="text-xl">➕</span>
                <h3 class="text-base font-bold text-slate-900 dark:text-white">Add Topic to Current Active Track</h3>
            </div>
            
            <form id="add-topic-form" onsubmit="handleFormSubmit(event)" class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                <div class="md:col-span-4">
                    <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-2" id="target-phase-label">Select Phase/Module Location</label>
                    <select id="topic-target-module" class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-850 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brandteal">
                        <!-- Populated programmatically -->
                    </select>
                </div>
                
                <div class="md:col-span-4">
                    <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-2">Topic / Video Name</label>
                    <input type="text" id="topic-name-input" placeholder="e.g. Advanced CI/CD Strategies" required class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-850 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brandteal">
                </div>

                <div class="md:col-span-2" id="duration-input-container">
                    <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-2">Duration</label>
                    <input type="text" id="topic-duration-input" placeholder="e.g. 1h 45m" class="w-full px-3 py-2 text-sm bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-850 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brandteal">
                </div>

                <div class="md:col-span-2 flex flex-col items-start pb-2">
                    <label class="flex items-center gap-2 cursor-pointer select-none">
                        <input type="checkbox" id="topic-important-input" class="w-4.5 h-4.5 rounded text-brandteal focus:ring-brandteal border-slate-300 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 cursor-pointer transition">
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-300 uppercase tracking-wide">Must Need? 🔥</span>
                    </label>
                </div>

                <div class="md:col-span-12 flex justify-end">
                    <button type="submit" class="px-4 py-2 bg-brandteal hover:bg-teal-800 text-white font-bold rounded-lg text-xs shadow transition-transform duration-200 hover:scale-105">
                        Add to Syllabus
                    </button>
                </div>
            </form>
        </section>

        <!-- Digital Filtering and Controls (Hidden during PDF print) -->
        <section id="controls" class="mb-8 p-4 bg-white dark:bg-slate-950 rounded-xl shadow border border-slate-200 dark:border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4 no-print">
            
            <!-- Search -->
            <div class="relative w-full md:w-80">
                <input type="text" id="search-bar" placeholder="Search syllabus topics..." class="w-full pl-9 pr-4 py-2 text-sm bg-slate-50 dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-brandteal text-slate-800 dark:text-slate-100 placeholder-slate-400">
                <svg class="absolute left-3 top-2.5 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>

            <!-- Custom Filters and Quick Actions (Mode Dependent) -->
            <div class="flex flex-wrap items-center gap-2 w-full md:w-auto md:justify-end" id="filters-wrapper">
                <!-- Injected programmatically based on activeMode -->
            </div>
        </section>

        <!-- Dynamic Workspace Content Holder -->
        <section id="workspace-container" class="space-y-8">
            <!-- Programmatic syllabus components mount here -->
        </section>

    </main>

    <!-- Dynamic Toast Notification Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"></div>

    <!-- Complete Databases: MERN & Screenshot Multi-Zones -->
    <script>
        // BASE UNTOUCHED MERN DATA
        const BASE_MERN_SYLLABUS = [
            {
                phaseTitle: "Phase 1: HTML, CSS, Responsive UI/UX & Tailwind",
                phaseDuration: "5 Hours, 41 Minutes, 15 Seconds",
                phaseObjective: "Translate static design mockups into beautiful, responsive components and modular static layouts.",
                lectures: [
                    { id: 1, name: "Week 0.2 - HTML basic (Tags, Attributes)", duration: "33m 47s", priority: 5, seconds: 2027 },
                    { id: 2, name: "Week 0.3 - CSS Basic", duration: "59m 41s", priority: 5, seconds: 3581 },
                    { id: 3, name: "8.0 | Tailwind from Cohort 1", duration: "1h 53m 11s", priority: 5, seconds: 6791 },
                    { id: 4, name: "8.1 | Tailwind class - Cohort 2", duration: "2h 14m 36s", priority: 5, seconds: 8076 }
                ]
            },
            {
                phaseTitle: "Phase 2: JavaScript Foundations & Async Engine",
                phaseDuration: "9 Hours, 49 Minutes, 10 Seconds",
                phaseObjective: "Master JS engine mechanics, closures, advanced scope chains, array transformations, and callbacks.",
                lectures: [
                    { id: 5, name: "Week 1.2 | JS Foundations", duration: "2h 22m 11s", priority: 5, seconds: 8531 },
                    { id: 6, name: "Week 1.3 | Offline class | Basic JS APIs", duration: "1h 07m 15s", priority: 4, seconds: 4035 },
                    { id: 7, name: "Week 1.4 | Loops, Functions, Callback functions", duration: "35m 28s", priority: 5, seconds: 2128 },
                    { id: 8, name: "2.6 | map, filter, arrow fns", duration: "19m 13s", priority: 5, seconds: 1153 },
                    { id: 9, name: "Week 1.5 | Async functions, Promises and async await", duration: "1h 16m 10s", priority: 5, seconds: 4570 },
                    { id: 10, name: "Week 2.1 | Promises and async JS revision, doubt session (Zoom upload)", duration: "3h 05m 43s", priority: 5, seconds: 11143 },
                    { id: 11, name: "Week 3.0.2 | Js Foundation Revision", duration: "1m 28s", priority: 3, seconds: 88 },
                    { id: 12, name: "8.3 | axios vs fetch", duration: "21m 42s", priority: 5, seconds: 1302 }
                ]
            },
            {
                phaseTitle: "Phase 3: React.js Ecosystem & Client-Side Runtimes",
                phaseDuration: "19 Hours, 43 Minutes, 13 Seconds",
                phaseObjective: "Transition from browser DOM interactions into virtual component trees, lifecycles, and TypeScript.",
                lectures: [
                    { id: 13, name: "3.5 | DOM Introduction (Laisha)", duration: "1h 26m 42s", priority: 4, seconds: 5202 },
                    { id: 14, name: "4.0.1 | DOM Introduction", duration: "1h 26m 45s", priority: 4, seconds: 5205 },
                    { id: 15, name: "4.1 | DOM Introduction", duration: "Included in 4.0.1", priority: 4, seconds: 0 },
                    { id: 16, name: "4.2 | React foundation", duration: "2h 14m 46s", priority: 5, seconds: 8086 },
                    { id: 17, name: "5.1 | Diving into React", duration: "2h 45m 25s", priority: 5, seconds: 9925 },
                    { id: 18, name: "week 5.2 | Creating a To-Do App (Re-upload)", duration: "1h 58m 51s", priority: 5, seconds: 7131 },
                    { id: 19, name: "Week 6.1 | Popular react hooks, React deep dive", duration: "2h 29m 27s", priority: 5, seconds: 8967 },
                    { id: 20, name: "Week 6.2 | useEffect, useMemo, useCallback", duration: "2h 33m 03s", priority: 5, seconds: 9183 },
                    { id: 21, name: "6.3 | Recap of everything in react, Intro to useRef", duration: "1h 10m 34s", priority: 4, seconds: 4234 },
                    { id: 22, name: "9.2 | Typescript Intro", duration: "2h 18m 36s", priority: 5, seconds: 8316 },
                    { id: 23, name: "9.3 | Generics, enums, imports, exports", duration: "42m 14s", priority: 4, seconds: 2534 }
                ]
            },
            {
                phaseTitle: "Phase 4: State Management & Optimization Patterns",
                phaseDuration: "7 Hours, 47 Minutes, 14 Seconds",
                phaseObjective: "Abstract client logic, bypass prop drilling, and optimize component re-render footprints.",
                lectures: [
                    { id: 24, name: "7.1 | Context, prop drilling", duration: "1h 48m 13s", priority: 5, seconds: 6493 },
                    { id: 25, name: "7.2 | Recoil", duration: "2h 05m 21s", priority: 5, seconds: 7521 },
                    { id: 26, name: "7.3 | Recoil Deep dive", duration: "1h 33m 36s", priority: 4, seconds: 5616 },
                    { id: 27, name: "9.1 | Custom hooks", duration: "2h 20m 04s", priority: 5, seconds: 8404 }
                ]
            },
            {
                phaseTitle: "Phase 5: Node.js, Express.js & Backend Core",
                phaseDuration: "9 Hours, 41 Minutes, 07 Seconds",
                phaseObjective: "Configure runtime listeners, set up modular routing controllers, and validate payloads with Zod.",
                lectures: [
                    { id: 28, name: "Week 2.2 | Express and Backend (Zoom upload)", duration: "2h 55m 30s", priority: 5, seconds: 10530 },
                    { id: 29, name: "2.3 | Bash and terminal", duration: "34m 34s", priority: 3, seconds: 2074 },
                    { id: 30, name: "Week 2.4 | Bash and Terminal (Advance)", duration: "56m 05s", priority: 3, seconds: 3365 },
                    { id: 31, name: "Week 2.5 | Express basics", duration: "1h 18m 44s", priority: 5, seconds: 4724 },
                    { id: 32, name: "2.7 | Git basics to advance", duration: "1h 26m 44s", priority: 4, seconds: 5204 },
                    { id: 33, name: "Week 3.0.1 | What We're Covering In Week 3", duration: "57s", priority: 3, seconds: 57 },
                    { id: 34, name: "Week 3.0.3 | Node.Js Runtime", duration: "2m 50s", priority: 4, seconds: 170 },
                    { id: 35, name: "Week 3.0.4 | Express Basics", duration: "1m 43s", priority: 4, seconds: 103 },
                    { id: 36, name: "Week 3.0.5 | Express Advance Intro", duration: "1m 02s", priority: 3, seconds: 62 },
                    { id: 37, name: "Week 3.1 | Middlewares, global catches and zod", duration: "2h 33m 56s", priority: 5, seconds: 9236 },
                    { id: 38, name: "3.3 | Middleware recap and assignments", duration: "47m 06s", priority: 4, seconds: 2826 }
                ]
            },
            {
                phaseTitle: "Phase 6A: Database Engineering (MongoDB Strictly)",
                phaseDuration: "2 Hours, 18 Minutes, 01 Second",
                phaseObjective: "Configure active document clusters, construct mongoose ODM schemas, and perform secure CRUD queries.",
                lectures: [
                    { id: 39, name: "Week 3.0.6 | Databases Intro", duration: "1m 22s", priority: 3, seconds: 82 },
                    { id: 40, name: "Week 3.0.7 | Mongo Installation", duration: "6m 43s", priority: 3, seconds: 403 },
                    { id: 41, name: "4.3 | Mongo Deep dive, Assignments", duration: "2h 09m 56s", priority: 5, seconds: 7796 }
                ]
            },
            {
                phaseTitle: "Phase 6B: Relational Database Track (SQL & Prisma - Optional)",
                phaseDuration: "11 Hours, 51 Minutes, 04 Seconds",
                phaseObjective: "Relational tables are not immediately required for standard MongoDB tracks. Keep this section isolated for secondary focus.",
                lectures: [
                    { id: 42, name: "Week 3.0.8 | Postgres Installation", duration: "1m 10s", priority: 0, seconds: 70 },
                    { id: 43, name: "week 10.1 | Postgres", duration: "2h 28m 30s", priority: 0, seconds: 8910 },
                    { id: 44, name: "12.4 | SQL Joins and Relationships", duration: "1h 26m 04s", priority: 0, seconds: 5164 },
                    { id: 45, name: "10.0.01 | Cohort 1 Postgress Video", duration: "1h 32m 24s", priority: 0, seconds: 5544 },
                    { id: 46, name: "week 10.2 | Prisma", duration: "2h 03m 57s", priority: 0, seconds: 7437 },
